{
  "ConnectionStrings": {
    "Simulation": "Data Source=simulation.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "uk.osric": "Debug"
    }
  },
  "Simulation": {
    "TickRateHz": 10
  },
  "Terrain": {
    "DefaultSeed": 1729,
    "DefaultSize": 64,
    "ErosionPasses": 1280,
    "UpscaleFactor": 8,
    "SmoothnessStopStep": 8,
    "RaindropErosion": {
      "DropPathLength": 64,
      "NeighborSampleCount": 8,
      "ErosionStrength": 0.02,
      "DepositionRatio": 0.25
    }
  },
  "OpenTelemetry": {
    "OtlpEndpoint": ""
  },
  "AllowedHosts": "*"
}
